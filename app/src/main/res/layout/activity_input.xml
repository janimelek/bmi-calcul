<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_input.xml — BMI data-entry screen.

    Root: ScrollView so content scrolls on small devices.
    Sections:
      1. Page header      — "Enter Your Details"
      2. Gender selector  — two side-by-side CardViews (Male / Female)
      3. Height section   — SeekBar 100–220 cm + minus/plus buttons
      4. Weight section   — SeekBar 30–200 kg  + minus/plus buttons
      5. Age section      — SeekBar 1–100      + minus/plus buttons
      6. Calculate button — full-width, 56dp, colorPrimary background
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="24dp">

        <!-- ══════════════════════════════════════════════════════════
             1. PAGE HEADER
             ══════════════════════════════════════════════════════════ -->
        <TextView
            android:id="@+id/tvInputHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:text="@string/label_enter_details"
            android:textColor="@color/colorPrimary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- ══════════════════════════════════════════════════════════
             2. GENDER SELECTION
             ══════════════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/label_gender"
            android:textColor="@color/onSurface"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!--
            Two equal-weight CardViews.
            Java will toggle their inner-panel backgrounds between
            @drawable/card_gender_selected and @drawable/card_gender_unselected.
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <!-- Male card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvMale"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface">

                <!-- Inner panel — Java sets background drawable for selected/unselected -->
                <LinearLayout
                    android:id="@+id/llMalePanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:background="@drawable/card_gender_selected">

                    <ImageView
                        android:id="@+id/ivMaleIcon"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_male"
                        android:tint="@color/colorPrimary"
                        android:contentDescription="@string/cd_male" />

                    <TextView
                        android:id="@+id/tvMaleLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/label_male"
                        android:textColor="@color/colorPrimary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Female card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvFemale"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:id="@+id/llFemalePanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:background="@drawable/card_gender_unselected">

                    <ImageView
                        android:id="@+id/ivFemaleIcon"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_female"
                        android:tint="@color/hint"
                        android:contentDescription="@string/cd_female" />

                    <TextView
                        android:id="@+id/tvFemaleLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/label_female"
                        android:textColor="@color/hint"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════
             3. HEIGHT SECTION  (SeekBar offset: value = progress + 100)
             ══════════════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/label_height"
            android:textColor="@color/onSurface"
            android:textSize="14sp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Dynamic value label -->
                <TextView
                    android:id="@+id/tvHeightValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center"
                    android:text="175 cm"
                    android:textColor="@color/colorPrimary"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <!-- Minus · SeekBar · Plus row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageButton
                        android:id="@+id/ibHeightMinus"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_minus"
                        android:tint="@color/colorPrimary"
                        android:background="@drawable/card_gender_unselected"
                        android:contentDescription="@string/cd_decrease"
                        android:padding="8dp" />

                    <SeekBar
                        android:id="@+id/sbHeight"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="12dp"
                        android:max="120"
                        android:progress="75"
                        android:progressTint="@color/colorPrimary"
                        android:thumbTint="@color/colorPrimary" />

                    <ImageButton
                        android:id="@+id/ibHeightPlus"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_plus"
                        android:tint="@color/colorPrimary"
                        android:background="@drawable/card_gender_unselected"
                        android:contentDescription="@string/cd_increase"
                        android:padding="8dp" />

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════════════════════════════════════════
             4. WEIGHT SECTION  (SeekBar offset: value = progress + 30)
             ══════════════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/label_weight_section"
            android:textColor="@color/onSurface"
            android:textSize="14sp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvWeightValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center"
                    android:text="70 kg"
                    android:textColor="@color/colorPrimary"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageButton
                        android:id="@+id/ibWeightMinus"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_minus"
                        android:tint="@color/colorPrimary"
                        android:background="@drawable/card_gender_unselected"
                        android:contentDescription="@string/cd_decrease"
                        android:padding="8dp" />

                    <SeekBar
                        android:id="@+id/sbWeight"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="12dp"
                        android:max="170"
                        android:progress="40"
                        android:progressTint="@color/colorPrimary"
                        android:thumbTint="@color/colorPrimary" />

                    <ImageButton
                        android:id="@+id/ibWeightPlus"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_plus"
                        android:tint="@color/colorPrimary"
                        android:background="@drawable/card_gender_unselected"
                        android:contentDescription="@string/cd_increase"
                        android:padding="8dp" />

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════════════════════════════════════════
             5. AGE SECTION  (SeekBar offset: value = progress + 1)
             ══════════════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/label_age"
            android:textColor="@color/onSurface"
            android:textSize="14sp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvAgeValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center"
                    android:text="25 yrs"
                    android:textColor="@color/colorPrimary"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageButton
                        android:id="@+id/ibAgeMinus"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_minus"
                        android:tint="@color/colorPrimary"
                        android:background="@drawable/card_gender_unselected"
                        android:contentDescription="@string/cd_decrease"
                        android:padding="8dp" />

                    <SeekBar
                        android:id="@+id/sbAge"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="12dp"
                        android:max="99"
                        android:progress="24"
                        android:progressTint="@color/colorPrimary"
                        android:thumbTint="@color/colorPrimary" />

                    <ImageButton
                        android:id="@+id/ibAgePlus"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_plus"
                        android:tint="@color/colorPrimary"
                        android:background="@drawable/card_gender_unselected"
                        android:contentDescription="@string/cd_increase"
                        android:padding="8dp" />

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════════════════════════════════════════
             6. CALCULATE BMI BUTTON
             No onClick set here — handled entirely in InputActivity.java.
             ══════════════════════════════════════════════════════════ -->
        <Button
            android:id="@+id/btnCalculateBmi"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/btn_calculate_bmi"
            android:text="@string/btn_calculate_bmi"
            android:textColor="@color/onPrimary"
            android:textSize="17sp"
            android:textStyle="bold"
            android:stateListAnimator="@null"
            android:letterSpacing="0.04" />

    </LinearLayout>
</ScrollView>
